{
  "info": {
    "_postman_id": "2f1d0ac9-1f60-4f5e-b781-3a4b1d7472a1",
    "name": "grapevine api",
    "description": "Fast test collection for Grapevine API. Uses {{base_url}} and shared ids captured from responses.\n\nAuth: CAS login is a redirect flow. Log in via the browser at {{base_url}}/auth/login, then copy the session cookie `id` into Postman (Cookies for {{base_url}}).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "auth",
      "item": [
        {
          "name": "start cas login",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/auth/login",
              "host": ["{{base_url}}"],
              "path": ["auth", "login"]
            }
          }
        },
        {
          "name": "cas callback",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/auth/callback?ticket=ST-EXAMPLE",
              "host": ["{{base_url}}"],
              "path": ["auth", "callback"],
              "query": [
                {
                  "key": "ticket",
                  "value": "ST-EXAMPLE"
                }
              ]
            }
          }
        },
        {
          "name": "logout",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{base_url}}/auth/logout",
              "host": ["{{base_url}}"],
              "path": ["auth", "logout"]
            }
          }
        }
      ]
    },
    {
      "name": "courses",
      "item": [
        {
          "name": "list courses",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/courses",
              "host": ["{{base_url}}"],
              "path": ["courses"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (Array.isArray(json) && json.length > 0) {",
                  "  pm.environment.set('course_code', json[0].code);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "get course",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/courses/{{course_code}}",
              "host": ["{{base_url}}"],
              "path": ["courses", "{{course_code}}"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "const offerings = json && json.offerings;",
                  "if (Array.isArray(offerings) && offerings.length > 0) {",
                  "  pm.environment.set('offering_id', offerings[0].id);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "list course reviews",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/courses/{{course_code}}/reviews",
              "host": ["{{base_url}}"],
              "path": ["courses", "{{course_code}}", "reviews"]
            }
          }
        }
      ]
    },
